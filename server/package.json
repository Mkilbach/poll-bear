{
  "name": "server",
  "version": "1.1.0",
  "description": "This project was bootstrapped with Fastify-CLI.",
  "type": "module",
  "main": "app.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "node --import tsx/esm --test test/**/*.test.ts",
    "build": "tsc",
    "start": "fastify start -l info --import tsx/esm app.ts",
    "dev": "fastify start -w -l info -P --import tsx/esm app.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/autoload": "^6.0.0",
    "@fastify/env": "^5.0.3",
    "@fastify/sensible": "^6.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "fastify": "^5.0.0",
    "fastify-cli": "^7.4.1",
    "fastify-plugin": "^5.0.0",
    "mongoose": "^9.3.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
